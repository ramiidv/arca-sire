{
  "name": "@ramiidv/arca-sire",
  "version": "0.1.0",
  "description": "TypeScript SDK para el web service SIRE (Sistema Integral de Retenciones Electronicas) de ARCA (ex AFIP)",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "llms.txt",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "arca",
    "afip",
    "sire",
    "sicore",
    "retenciones",
    "percepciones",
    "argentina",
    "sdk",
    "typescript"
  ],
  "author": "ramiidv",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ramiidv/arca-sire.git"
  },
  "homepage": "https://arca-sdk.dev/sire",
  "bugs": {
    "url": "https://github.com/ramiidv/arca-sire/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@ramiidv/arca-common": "^0.1.0",
    "fast-xml-parser": "^5.0.0",
    "node-forge": "^1.3.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/node-forge": "^1.3.0",
    "typescript": "^5.7.0",
    "vitest": "^3.2.4"
  }
}
